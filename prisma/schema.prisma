generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CLIENT
  PROVIDER
  ADMIN
}

enum VerificationSource {
  GLOWITH
  EMPLOYER
}

enum Plan {
  STARTER
  PRO
  BUSINESS
}

model BlogPost {
  id            String    @id @default(cuid())
  slug          String    @unique
  title         String
  excerpt       String
  coverImageUrl String?
  content       String    // markdown
  published     Boolean   @default(false)
  publishedAt   DateTime?
  authorName    String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model PlatformConfig {
  id             String   @id @default("global")
  depositPercent Int      @default(20)
  updatedAt      DateTime @updatedAt
}

enum ProviderType {
  FREELANCER
  BUSINESS
}

enum BookingStatus {
  PENDING_DEPOSIT
  CONFIRMED
  COMPLETED
  CANCELLED
}

// NextAuth required tables
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  name          String
  role          UserRole  @default(CLIENT)
  totpSecret    String?
  totpEnabled   Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts               Account[]
  sessions               Session[]
  providerProfile        ProviderProfile?
  bookings               Booking[]
  sentMessages           Message[]
  messageReactions       MessageReaction[]
  conversationMemberships ConversationParticipant[]
  ratings                Rating[]
  passkeys               Passkey[]
}

model Passkey {
  id           String    @id @default(cuid())
  userId       String
  credentialId String    @unique
  publicKey    Bytes
  counter      BigInt    @default(0)
  deviceType   String
  backedUp     Boolean   @default(false)
  transports   String?
  name         String    @default("Passkey")
  createdAt    DateTime  @default(now())
  lastUsed     DateTime?
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ProviderProfile {
  id           String   @id @default(cuid())
  userId       String   @unique
  handle       String   @unique
  businessName String
  category     String
  bio          String
  city         String
  latitude     Float
  longitude    Float
  providerType     ProviderType @default(FREELANCER)
  parentBusinessId String?
  avatarUrl        String?
  verified         Boolean  @default(false)
  verifiedBy       VerificationSource?
  canPostToCompany Boolean  @default(false)
  plan             Plan     @default(STARTER)
  storageBytes     BigInt   @default(0)
  storageQuotaBytes BigInt  @default(2147483648) // 2 GB
  isDemo           Boolean  @default(false)
  mobile           Boolean  @default(false)
  studio           Boolean  @default(true)
  // Cancellation & reschedule policy (agents inherit from parent business)
  cancelNoticeHours     Int?
  cancelFeePercent      Int?
  rescheduleNoticeHours Int?
  rescheduleFeePercent  Int?
  policyText            String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  parentBusiness  ProviderProfile? @relation("BusinessAgents", fields: [parentBusinessId], references: [id], onDelete: SetNull)
  agents          ProviderProfile[] @relation("BusinessAgents")
  services   Service[]
  posts      PortfolioPost[]
  bookings   Booking[]
  follows    Follow[]
  saves      SavedProvider[]
  ratings    Rating[]
  coupons    Coupon[]
  amenities  ProviderAmenity[]
}

model ProviderAmenity {
  id                String          @id @default(cuid())
  providerProfileId String
  amenityKey        String          // e.g. "free_wifi", "first_aid_kit"
  value             String?         // optional extra value, e.g. "22" for avg_temperature
  providerProfile   ProviderProfile @relation(fields: [providerProfileId], references: [id], onDelete: Cascade)

  @@unique([providerProfileId, amenityKey])
}

enum DiscountType {
  PERCENT
  FIXED
}

model Coupon {
  id                String       @id @default(cuid())
  providerProfileId String
  code              String
  discountType      DiscountType
  discountValue     Int          // percent (1-100) or amount in cents
  maxRedemptions    Int?
  redemptions       Int          @default(0)
  expiresAt         DateTime?
  active            Boolean      @default(true)
  createdAt         DateTime     @default(now())

  providerProfile ProviderProfile @relation(fields: [providerProfileId], references: [id], onDelete: Cascade)

  @@unique([providerProfileId, code])
}

model Rating {
  id                String   @id @default(cuid())
  userId            String
  providerProfileId String
  stars             Int
  comment           String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  providerProfile ProviderProfile @relation(fields: [providerProfileId], references: [id], onDelete: Cascade)
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, providerProfileId])
}

model Service {
  id                String   @id @default(cuid())
  providerProfileId String
  name              String
  category          String
  durationMinutes   Int
  priceCents        Int
  depositCents      Int
  active            Boolean  @default(true)
  createdAt         DateTime @default(now())

  providerProfile ProviderProfile @relation(fields: [providerProfileId], references: [id], onDelete: Cascade)
  bookings        Booking[]
  extras          ServiceExtra[]
}

model ServiceExtra {
  id              String   @id @default(cuid())
  serviceId       String
  name            String
  description     String?
  priceCents      Int      @default(0)
  durationMinutes Int      @default(0)
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())

  service       Service        @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  bookingExtras BookingExtra[]
}

model PortfolioPost {
  id                String   @id @default(cuid())
  providerProfileId String
  imageUrl          String
  images            String[] @default([])
  caption           String
  tags              String[]
  likes             Int      @default(0)
  saves             Int      @default(0)
  featured          Boolean  @default(false)
  sizeBytes         Int      @default(0)
  serviceId         String?
  authorProfileId   String?
  authorName        String?
  createdAt         DateTime @default(now())

  providerProfile ProviderProfile @relation(fields: [providerProfileId], references: [id], onDelete: Cascade)
}

model Booking {
  id                String        @id @default(cuid())
  clientId          String
  providerProfileId String
  serviceId         String
  startsAt          DateTime
  notes             String?
  status            BookingStatus @default(PENDING_DEPOSIT)
  depositCents      Int
  durationMinutes   Int           @default(0)
  couponId          String?
  discountCents     Int           @default(0)
  paymentProvider   String?
  paymentIntentId   String?
  checkedInAt       DateTime?
  checkedInById     String?
  checkInCode       String?
  checkInCodeExpiresAt DateTime?
  noShowAt          DateTime?
  completedAt       DateTime?
  feedbackRequestedAt DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  client          User            @relation(fields: [clientId], references: [id])
  providerProfile ProviderProfile @relation(fields: [providerProfileId], references: [id])
  service         Service         @relation(fields: [serviceId], references: [id])
  items           BookingItem[]
  extras          BookingExtra[]
}

model BookingExtra {
  id              String @id @default(cuid())
  bookingId       String
  serviceExtraId  String
  name            String
  priceCents      Int
  durationMinutes Int    @default(0)

  booking      Booking      @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  serviceExtra ServiceExtra @relation(fields: [serviceExtraId], references: [id])
}

model BookingItem {
  id              String  @id @default(cuid())
  bookingId       String
  serviceId       String
  name            String
  priceCents      Int
  durationMinutes Int

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
}

model Conversation {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  participants ConversationParticipant[]
  messages     Message[]
}

model ConversationParticipant {
  id             String    @id @default(cuid())
  conversationId String
  userId         String
  lastReadAt     DateTime?

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
}

model Message {
  id             String    @id @default(cuid())
  conversationId String
  senderId       String
  body           String    @db.Text
  createdAt      DateTime  @default(now())
  editedAt       DateTime?

  conversation Conversation      @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User              @relation(fields: [senderId], references: [id], onDelete: Cascade, map: "Message_sender_fkey")
  reactions    MessageReaction[]
}

model MessageReaction {
  id        String   @id @default(cuid())
  messageId String
  userId    String
  emoji     String
  createdAt DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
}

model Follow {
  id                String   @id @default(cuid())
  userId            String
  providerProfileId String
  createdAt         DateTime @default(now())

  providerProfile ProviderProfile @relation(fields: [providerProfileId], references: [id], onDelete: Cascade)

  @@unique([userId, providerProfileId])
}

model RestrictedName {
  id        String   @id @default(cuid())
  name      String   @unique
  reason    String?
  createdAt DateTime @default(now())
  createdBy String?
}

model SavedProvider {
  id                String   @id @default(cuid())
  userId            String
  providerProfileId String
  createdAt         DateTime @default(now())

  providerProfile ProviderProfile @relation(fields: [providerProfileId], references: [id], onDelete: Cascade)

  @@unique([userId, providerProfileId])
}
