generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CLIENT
  PROVIDER
  ADMIN
}

enum VerificationSource {
  GLOWITH
  EMPLOYER
}

enum Plan {
  STARTER
  PRO
  BUSINESS
}

model BlogPost {
  id            String    @id @default(cuid())
  slug          String    @unique
  title         String
  excerpt       String
  coverImageUrl String?
  content       String    // markdown
  published     Boolean   @default(false)
  publishedAt   DateTime?
  authorName    String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model PlatformConfig {
  id             String   @id @default("global")
  depositPercent Int      @default(20)
  updatedAt      DateTime @updatedAt
}

enum ProviderType {
  FREELANCER
  BUSINESS
}

enum BookingStatus {
  PENDING_DEPOSIT
  CONFIRMED
  COMPLETED
  CANCELLED
}

// NextAuth required tables
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  emailVerified DateTime?
  image         String?
  passwordHash String?
  name         String
  role         UserRole @default(CLIENT)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  accounts        Account[]
  sessions        Session[]
  providerProfile ProviderProfile?
  bookings        Booking[]
  messages        Message[]
  ratings         Rating[]
}

model ProviderProfile {
  id           String   @id @default(cuid())
  userId       String   @unique
  handle       String   @unique
  businessName String
  category     String
  bio          String
  city         String
  latitude     Float
  longitude    Float
  providerType     ProviderType @default(FREELANCER)
  parentBusinessId String?
  avatarUrl        String?
  verified         Boolean  @default(false)
  verifiedBy       VerificationSource?
  canPostToCompany Boolean  @default(false)
  plan             Plan     @default(STARTER)
  isDemo           Boolean  @default(false)
  mobile           Boolean  @default(false)
  studio           Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  parentBusiness  ProviderProfile? @relation("BusinessAgents", fields: [parentBusinessId], references: [id], onDelete: SetNull)
  agents          ProviderProfile[] @relation("BusinessAgents")
  services  Service[]
  posts     PortfolioPost[]
  bookings  Booking[]
  messages  Message[]
  follows   Follow[]
  saves     SavedProvider[]
  ratings   Rating[]
  coupons   Coupon[]
}

enum DiscountType {
  PERCENT
  FIXED
}

model Coupon {
  id                String       @id @default(cuid())
  providerProfileId String
  code              String
  discountType      DiscountType
  discountValue     Int          // percent (1-100) or amount in cents
  maxRedemptions    Int?
  redemptions       Int          @default(0)
  expiresAt         DateTime?
  active            Boolean      @default(true)
  createdAt         DateTime     @default(now())

  providerProfile ProviderProfile @relation(fields: [providerProfileId], references: [id], onDelete: Cascade)

  @@unique([providerProfileId, code])
}

model Rating {
  id                String   @id @default(cuid())
  userId            String
  providerProfileId String
  stars             Int
  comment           String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  providerProfile ProviderProfile @relation(fields: [providerProfileId], references: [id], onDelete: Cascade)
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, providerProfileId])
}

model Service {
  id                String   @id @default(cuid())
  providerProfileId String
  name              String
  category          String
  durationMinutes   Int
  priceCents        Int
  depositCents      Int
  active            Boolean  @default(true)
  createdAt         DateTime @default(now())

  providerProfile ProviderProfile @relation(fields: [providerProfileId], references: [id], onDelete: Cascade)
  bookings        Booking[]
}

model PortfolioPost {
  id                String   @id @default(cuid())
  providerProfileId String
  imageUrl          String
  caption           String
  tags              String[]
  likes             Int      @default(0)
  saves             Int      @default(0)
  authorProfileId   String?
  authorName        String?
  createdAt         DateTime @default(now())

  providerProfile ProviderProfile @relation(fields: [providerProfileId], references: [id], onDelete: Cascade)
}

model Booking {
  id                String        @id @default(cuid())
  clientId          String
  providerProfileId String
  serviceId         String
  startsAt          DateTime
  notes             String?
  status            BookingStatus @default(PENDING_DEPOSIT)
  depositCents      Int
  durationMinutes   Int           @default(0)
  couponId          String?
  discountCents     Int           @default(0)
  paymentProvider   String?
  paymentIntentId   String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  client          User            @relation(fields: [clientId], references: [id])
  providerProfile ProviderProfile @relation(fields: [providerProfileId], references: [id])
  service         Service         @relation(fields: [serviceId], references: [id])
  items           BookingItem[]
}

model BookingItem {
  id              String  @id @default(cuid())
  bookingId       String
  serviceId       String
  name            String
  priceCents      Int
  durationMinutes Int

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
}

model Message {
  id                String   @id @default(cuid())
  senderId          String
  providerProfileId String
  body              String
  createdAt         DateTime @default(now())

  sender          User            @relation(fields: [senderId], references: [id])
  providerProfile ProviderProfile @relation(fields: [providerProfileId], references: [id])
}

model Follow {
  id                String   @id @default(cuid())
  userId            String
  providerProfileId String
  createdAt         DateTime @default(now())

  providerProfile ProviderProfile @relation(fields: [providerProfileId], references: [id], onDelete: Cascade)

  @@unique([userId, providerProfileId])
}

model RestrictedName {
  id        String   @id @default(cuid())
  name      String   @unique
  reason    String?
  createdAt DateTime @default(now())
  createdBy String?
}

model SavedProvider {
  id                String   @id @default(cuid())
  userId            String
  providerProfileId String
  createdAt         DateTime @default(now())

  providerProfile ProviderProfile @relation(fields: [providerProfileId], references: [id], onDelete: Cascade)

  @@unique([userId, providerProfileId])
}
